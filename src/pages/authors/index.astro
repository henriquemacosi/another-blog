---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const now = new Date();

const allAuthors = await getCollection('authors');

// Filtramos posts futuros e rascunhos
const allPosts = await getCollection('blog', ({ data }) => {
  return !data.draft && data.pubDate <= now;
});

// Ordenar posts por data
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Função para pegar posts de um autor específico (já filtrados por data)
const getAuthorPosts = (authorId: string) => {
  return sortedPosts.filter(post => 
    post.data.authors.some(ref => ref.id === authorId)
  ).slice(0, 3);
};
---

<BaseLayout title="Autores" description="Conheça os autores do nosso blog e leia seus posts mais recentes.">
    <h1 class="text-4xl font-bold mb-12">Autores</h1>

    <div class="grid gap-12">
      {allAuthors.map(author => {
        const { name, avatar, bio } = author.data;
        
        const authorPosts = getAuthorPosts(author.id);
        
        return (
          <section class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 flex flex-col md:flex-row gap-8">
            <div class="md:w-1/3 text-center md:text-left border-b md:border-b-0 md:border-r border-gray-100 pb-6 md:pb-0 md:pr-8">
            
              <Image 
                src={avatar.url} 
                alt={avatar.alt}
                width={200}  
                height={200}
                format="webp"
                class="w-32 h-32 rounded-full mx-auto md:mx-0 object-cover mb-4 border-4 border-blue-50"
              />
              <h2 class="text-2xl font-bold">
                <a href={`/authors/${author.id}/`} class="hover:text-blue-600 transition-colors">
                  {name}
                </a>
              </h2>
              <p class="text-gray-600 text-sm mt-3 leading-relaxed italic">
                "{bio}"
              </p>
            </div>

            <div class="md:w-2/3">
              <h3 class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-4">
                Posts Recentes de {name.split(' ')[0]}
              </h3>
              <div class="space-y-4">
                {authorPosts.map(post => {
                  const { title, image } = post.data;
                  return (
                    
                    <a href={`/blog/${post.id}/`} class="group flex items-center gap-4">
                      <Image 
                        src={image.url} 
                        alt={image.alt}
                        width={400}
                        height={225}
                        format="webp"
                        class="w-20 h-14 object-cover rounded-lg shadow-sm"
                      />
                      <h4 class="font-bold group-hover:text-blue-600 transition-colors line-clamp-1">
                        {title}
                      </h4>
                    </a>
                    );
                })}
                {authorPosts.length === 0 && <p class="text-gray-400 text-sm italic">Nenhum post publicado ainda.</p>}
              </div>
              <div class="mt-6">
                <a href={`/authors/${author.id}/`} class="text-blue-600 text-sm font-bold hover:underline">
                  Ver todos os posts →
                </a>
              </div>
            </div>
          </section>
        );
      })}
    </div>
</BaseLayout>