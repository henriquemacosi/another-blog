---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const now = new Date();

// 1. Buscar posts filtrando rascunhos E datas futuras
const allPosts = await getCollection('blog', ({ data }) => {
  return !data.draft && data.pubDate <= now;
});

// 2. Ordenar por data (Mais recente primeiro)
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// 3. Separar conteúdo para seções com segurança
const featuredPost = sortedPosts.length > 0 ? sortedPosts[0] : null;
const latestPosts = sortedPosts.slice(1, 4); 

// 4. Filtrar posts por categoria (Carreira)
const techPosts = allPosts
  .filter(post => 
    post.data.taxonomies?.categories?.some(cat => 
      (typeof cat === 'string' ? cat : cat.id) === 'Carreira'
    )
  )
  .slice(0, 4);

// 5. Tags populares (limitado a 10)
const tags = [...new Set(allPosts.flatMap(post => post.data.taxonomies?.tags || []))].slice(0, 10);
---

<BaseLayout title="Home | Meu Blog Incrível" description="Descrição do meu blog incrível para SEO">
  <section class="max-w-7xl mx-auto px-6 py-12">
      <h1 class="text-4xl font-black">Bem-vindo!</h1>
  </section>

  {/* SEÇÃO DE DESTAQUE */}
  <section class="max-w-7xl mx-auto px-6 py-12">
    {featuredPost ? (
      <div class="relative group overflow-hidden rounded-3xl bg-gray-900 h-[500px]">
        {featuredPost.data.image?.url && (
          // <img 
          //   src={featuredPost.data.image.url}
          //   alt={featuredPost.data.image.alt || ""} 
          //   class="absolute inset-0 w-full h-full object-cover opacity-60 group-hover:scale-105 transition-transform duration-700"
          // />
          <Image 
            src={featuredPost.data.image.url} 
            alt={featuredPost.data.image.alt}
            width={1200}
            height={630}
            format="webp"
            class="absolute inset-0 w-full h-full object-cover opacity-60 group-hover:scale-105 transition-transform duration-700"
          />
        )}
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent"></div>
        <div class="absolute bottom-0 p-8 md:p-12 max-w-3xl">
          <span class="bg-blue-600 text-white px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest mb-4 inline-block">
            Destaque Recente
          </span>
          <h2 class="text-3xl md:text-5xl font-black text-white mb-4 leading-tight">
            <a href={`/blog/${featuredPost.id}/`} class="hover:text-blue-400 transition-colors">
              {featuredPost.data.title}
            </a>
          </h2>
          <p class="text-gray-200 text-lg line-clamp-2 mb-6">{featuredPost.data.description}</p>
          <a href={`/blog/${featuredPost.id}/`} class="bg-white text-black px-6 py-3 rounded-full font-bold hover:bg-blue-500 hover:text-white transition-all">
            Ler Artigo Completo
          </a>
        </div>
      </div>
    ) : (
      <div class="bg-gray-100 rounded-3xl p-20 text-center">
        <p class="text-gray-500">Nenhum artigo disponível no momento.</p>
      </div>
    )}
  </section>

  {/* ÚLTIMAS NOVIDADES */}
  <section class="max-w-7xl mx-auto px-6 py-12 border-t border-gray-100">
    <div class="flex justify-between items-end mb-10">
      <div>
        <h2 class="text-3xl font-black">Últimas Novidades</h2>
        <p class="text-gray-500">O que há de novo no mundo da tecnologia e design.</p>
      </div>
      <a href="/blog/" class="text-blue-600 font-bold hover:underline">Ver tudo →</a>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      {latestPosts.map(post => (
        <article class="flex flex-col">
          <a href={`/blog/${post.id}/`} class="rounded-2xl overflow-hidden mb-4 aspect-video block bg-gray-100">
            {post.data.image?.url ? (
              // <img src={post.data.image.url} alt="" class="w-full h-full object-cover hover:scale-105 transition-transform" />

              <Image 
      src={post.data.image.url} 
      alt={post.data.image.alt}
      width={400}  // Tamanho menor para a listagem
      height={225}
      format="webp"
      class="w-full h-full object-cover hover:scale-105 transition-transform"
    />
            ) : (
              <div class="w-full h-full flex items-center justify-center text-gray-400">Sem imagem</div>
            )}
          </a>
          <h3 class="text-xl font-bold mb-2 hover:text-blue-600">
            <a href={`/blog/${post.id}/`}>{post.data.title}</a>
          </h3>
          <p class="text-gray-600 text-sm line-clamp-2">{post.data.description}</p>
        </article>
      ))}
    </div>
  </section>

  {/* ESPECIAL CARREIRA */}
  <section class="bg-gray-50 py-20">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="text-3xl font-black mb-10 flex items-center gap-4">
        Especial Carreira 
        <span class="h-1 w-20 bg-blue-600 rounded"></span>
      </h2>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {techPosts.length > 0 ? techPosts.map(post => (
          <a href={`/blog/${post.id}/`} class="bg-white p-4 rounded-xl shadow-sm hover:shadow-md transition-shadow">
            <h4 class="font-bold text-gray-800 line-clamp-2 mb-2">{post.data.title}</h4>
            <span class="text-xs text-gray-400">{post.data.pubDate.toLocaleDateString('pt-BR')}</span>
          </a>
        )) : (
          <p class="text-gray-400 col-span-full">Em breve novos artigos sobre carreira.</p>
        )}
      </div>
    </div>
  </section>

  {/* TAGS POPULARES */}
  <section class="max-w-7xl mx-auto px-6 py-20 text-center">
    <h2 class="text-2xl font-bold mb-8 italic text-gray-400">Tópicos Populares</h2>
    <div class="flex flex-wrap justify-center gap-3">
      {tags.map(tag => (
        <a href={`/tags/${tag.toLowerCase()}/`} class="px-6 py-2 border border-gray-200 rounded-full hover:border-blue-500 hover:text-blue-600 transition-all font-medium">
          #{tag}
        </a>
      ))}
    </div>
  </section>
</BaseLayout>